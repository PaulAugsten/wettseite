# Copy this file to .env.local and fill in real values. Never commit .env or .env.local.

# Supabase project URL and public (anon) key — safe to expose to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase service-role key — server-only, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Sentry DSNs — separate per runtime (browser vs server/edge).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Sentry build-time config — only needed for source map upload and release tagging.
# The build no-ops without these, so they're optional for local dev.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
